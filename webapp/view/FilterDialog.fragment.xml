<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:u="sap.ui.unified">
<Dialog id="dlgCargaArchivo" title="Cargar archivo Excel" draggable="true" resizable="true" contentWidth="400px">
<content>
<l:VerticalLayout class="sapUiSmallMargin">
<u:FileUploader id="fileUploader" fileType="xlsx" change="onFileChange" placeholder="Selecciona un archivo Excel (.xlsx)" style="Emphasized"/>
</l:VerticalLayout>
</content>
<beginButton>
<Button text="Procesar archivo" press="onProcesarExcel"/>
</beginButton>
<endButton>
<Button text="Cerrar" press="closeDialog"/>
</endButton>
</Dialog>
</core:FragmentDefinition>