<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <TableSelectDialog
        id="customerSelectDialog"
        title="{i18n>CUSTOMER_DIALOG_TITLE}"
        search=".onCustomerLiveChangeCustomer"
        confirm=".onCustomerConfirm"
        liveChange=".onCustomerLiveChangeCustomer"
        cancel=".onCustomerCancel"
        items="{CustomerSet>/customers}"
        noDataText="{i18n>CUSTOMER_DIALOG_NO_DATA}"
        growing="true"
        growingThreshold="20"
        contentHeight="40%"
        contentWidth="50%"
    >
        <!-- Definir columnas -->
        <columns>
            <Column>
                <Text text="{i18n>CUSTOMER_COL_ID}"/>
            </Column>
            <Column>
                <Text text="{i18n>CUSTOMER_COL_NAME}"/>
            </Column>
            <Column>
                <Text text="{i18n>CUSTOMER_COL_FULL_NAME}"/>
            </Column>
        </columns>

        <!-- Definir filas -->
        <ColumnListItem
            type="Active"
            icon="sap-icon://customer"
        >
            <cells>
                <Text text="{CustomerSet>Customer}"/>
                <Text text="{CustomerSet>CustomerName}"/>
                <Text text="{CustomerSet>CustomerFullName}"/>
            </cells>
        </ColumnListItem>

    </TableSelectDialog>
</core:FragmentDefinition>
